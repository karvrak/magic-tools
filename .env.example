# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/magic_tools_db"

# Authentication
# JWT secret for signing session tokens (generate a random 64+ char string)
JWT_SECRET="your-jwt-secret-here-generate-a-long-random-string"

# Admin account (used by seed script)
ADMIN_EMAIL="admin@magictools.local"
ADMIN_PASSWORD="your-secure-password-here"

# Legacy (kept for seed backwards-compat, prefer ADMIN_PASSWORD)
AUTH_PASSWORD="your-secure-password-here"

# Node environment (development | production)
NODE_ENV=development

# XAI API Key (for Grok AI features - OCR, deck suggestions)
XAI_API_KEY="your-xai-api-key-here"
