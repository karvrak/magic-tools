// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CARTES (mise a jour hebdomadaire via all_cards)
// ============================================
model Card {
  id              String   @id // Scryfall ID (unique par impression)
  oracleId        String   // ID unique par carte (toutes editions confondues)
  illustrationId  String?  // ID unique par illustration (pour regrouper meme art)
  name            String   // Nom anglais (reference)
  printedName     String?  // Nom traduit (FR si dispo)
  nameNormalized  String?  // Nom normalise (lowercase, sans accents) pour recherche rapide
  lang            String   @default("fr")
  layout          String   // normal, split, transform, mdfc...
  
  // Cout de mana
  manaCost        String?
  cmc             Float    @default(0)
  
  // Types
  typeLine        String   // Type anglais (reference)
  printedTypeLine String?  // Type traduit (FR si dispo)
  
  // Texte
  oracleText      String?  // Texte anglais (reference pour regles)
  printedText     String?  // Texte traduit (FR si dispo)
  flavorText      String?
  
  // Couleurs
  colors          String[] // ["W", "U", "B", "R", "G"]
  colorIdentity   String[]
  
  // Keywords
  keywords        String[]
  
  // Set
  setCode         String
  setName         String
  collectorNumber String
  rarity          String   // common, uncommon, rare, mythic
  
  // Images (URLs Scryfall)
  imageSmall      String?
  imageNormal     String?
  imageLarge      String?
  imageArtCrop    String?
  imageBorderCrop String?
  // Back face images for double-faced cards (transform, modal_dfc, etc.)
  imageNormalBack String?
  imageLargeBack  String?
  
  // Stats creatures
  power           String?
  toughness       String?
  loyalty         String?
  
  // Legalites (JSON)
  legalities      Json     // {standard: "legal", modern: "banned", ...}
  
  // Games
  games           String[] // ["paper", "arena", "mtgo"]
  
  // Art variant detection (pour filtrer les arts alternatifs)
  isPromo         Boolean  @default(false)  // Carte promo
  isBooster       Boolean  @default(true)   // Apparait dans les boosters
  frameEffects    String[] // ["showcase", "extendedart", "borderless", "inverted", ...]
  isFullArt       Boolean  @default(false)  // Art pleine page
  isTextless      Boolean  @default(false)  // Sans texte
  isVariation     Boolean  @default(false)  // Variation d'une carte existante
  
  // Prix specifiques a cette impression (pour arts alternatifs)
  priceEur        Float?
  priceEurFoil    Float?
  priceUsd        Float?
  priceUsdFoil    Float?
  
  // Dates
  releasedAt      DateTime?
  
  // Meta sync
  syncedAt        DateTime @default(now())
  
  // Relations
  deckCards       DeckCard[]
  wantlistItems   WantlistItem[]
  collectionItems CollectionItem[]
  
  // Index pour performance
  @@index([oracleId])
  @@index([illustrationId])
  @@index([name])
  @@index([printedName])
  @@index([nameNormalized])
  @@index([setCode])
  @@index([cmc])
  @@index([rarity])
  @@index([typeLine])
  @@index([isPromo])
  @@index([isBooster])
}

// ============================================
// PRIX (mise a jour quotidienne via oracle_cards)
// ============================================
model CardPrice {
  oracleId        String   @id // 1 prix par carte unique
  
  // Prix en EUR
  eur             Float?
  eurFoil         Float?
  
  // Prix en USD
  usd             Float?
  usdFoil         Float?
  
  // Prix MTGO (tix)
  tix             Float?
  
  // Meta
  updatedAt       DateTime @default(now())
  
  @@index([eur])
  @@index([usd])
}

// ============================================
// OWNERS (Propriétaires des decks)
// ============================================
model Owner {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#D4AF37") // Couleur d'affichage (gold par défaut)
  isDefault   Boolean  @default(false)     // Propriétaire par défaut pour nouveaux decks

  decks           Deck[]
  wantlistItems   WantlistItem[]
  collectionItems CollectionItem[]

  createdAt   DateTime @default(now())
}

// ============================================
// TAGS (pour catégoriser les decks)
// ============================================
model Tag {
  id          String   @id @default(cuid())
  name        String   @unique  // Nom du tag (unique, lowercase)
  color       String   @default("#8B5CF6") // Couleur d'affichage (violet par défaut)
  
  decks       Deck[]   // Relation many-to-many
  
  createdAt   DateTime @default(now())
  
  @@index([name])
}

// ============================================
// DECKS
// ============================================
enum DeckStatus {
  building  // En construction: prioritaire dans dropdown, exclu du total valeur
  active    // Deck normal (par défaut)
  locked    // Verrouillé: n'apparaît pas dans dropdown d'ajout
}

model Deck {
  id          String     @id @default(cuid())
  name        String
  description String?
  format      String?    // commander, modern, standard...
  coverImage  String?    // URL image de couverture (carte principale)
  status      DeckStatus @default(active)
  
  // Propriétaire du deck
  ownerId     String?
  owner       Owner?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  
  // Tags pour catégoriser le deck
  tags        Tag[]      // Relation many-to-many
  
  cards       DeckCard[]
  battlePlayers BattlePlayer[]

  // Relations vers les matchs joués
  matchesAsDeck1 Match[] @relation("Deck1Matches")
  matchesAsDeck2 Match[] @relation("Deck2Matches")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([ownerId])
  @@index([status])
}

model DeckCard {
  id          String   @id @default(cuid())
  
  deckId      String
  deck        Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  
  cardId      String   // Scryfall ID
  card        Card     @relation(fields: [cardId], references: [id])
  
  quantity    Int      @default(1)
  category    String   @default("mainboard") // mainboard, sideboard, maybeboard, commander
  
  @@unique([deckId, cardId, category])
  @@index([deckId])
}

// ============================================
// WANTLIST
// ============================================
model WantlistItem {
  id          String   @id @default(cuid())

  cardId      String   // Scryfall ID (edition specifique voulue)
  card        Card     @relation(fields: [cardId], references: [id])

  // Propriétaire de l'item wantlist
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  quantity    Int      @default(1)
  priority    String   @default("medium") // high, medium, low
  notes       String?

  // Suivi de commande
  isOrdered   Boolean  @default(false)    // Carte commandée
  orderedAt   DateTime?                   // Date de commande
  isReceived  Boolean  @default(false)    // Carte reçue
  receivedAt  DateTime?                   // Date de réception

  createdAt   DateTime @default(now())

  @@unique([cardId, ownerId])
  @@index([priority])
  @@index([ownerId])
  @@index([isOrdered])
  @@index([isReceived])
}

// ============================================
// COLLECTION
// ============================================
model CollectionItem {
  id          String   @id @default(cuid())

  cardId      String   // Scryfall ID (edition specifique possedee)
  card        Card     @relation(fields: [cardId], references: [id])

  // Propriétaire de l'item collection
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  quantity    Int      @default(1)
  condition   String   @default("nm")     // nm, lp, mp, hp, dmg
  isFoil      Boolean  @default(false)
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cardId, ownerId, isFoil, condition])
  @@index([ownerId])
  @@index([condition])
}

// ============================================
// LOGS DE SYNC
// ============================================
model SyncLog {
  id               String   @id @default(cuid())
  type             String   // "all_cards" | "oracle_cards"
  status           String   // "started" | "completed" | "failed"

  recordsProcessed Int?
  durationMs       Int?
  error            String?

  // Nouveautés détectées lors de cette sync
  detectedNewness  CardNewness[]

  createdAt        DateTime @default(now())
}

// ============================================
// CARD NEWNESS TRACKING (Nouvelles cartes/artworks)
// ============================================
enum NewnessType {
  NEW_CARD       // Premier oracleId vu dans cette DB
  NEW_ART        // Nouvel illustrationId pour un oracleId existant
}

model CardNewness {
  id              String       @id @default(cuid())

  // Identifiants conceptuels (pas de FK vers Card pour simplicité de cleanup)
  oracleId        String       // L'oracleId de la carte
  illustrationId  String?      // Pour NEW_ART: le nouvel illustrationId

  type            NewnessType
  detectedAt      DateTime     @default(now())

  // Référence la sync qui a détecté cette nouveauté
  syncLogId       String?
  syncLog         SyncLog?     @relation(fields: [syncLogId], references: [id], onDelete: SetNull)

  @@unique([oracleId, illustrationId])
  @@index([type])
  @@index([detectedAt])
  @@index([oracleId])
}

// ============================================
// BATTLES (Life Counter System)
// ============================================

// Modes de jeu disponibles
enum GameMode {
  CLASSIC_1V1       // 2 joueurs, 20 PV
  FREE_FOR_ALL_3    // 3 joueurs, 20 PV + Victory Points (combat only)
  TWO_HEADED_GIANT  // 2v2, 20 PV chacun avec transfert de vie
  COMMANDER         // 4 joueurs, 40 PV + Commander Damage tracking
}

model Battle {
  id          String         @id @default(cuid())
  mode        GameMode
  status      String         @default("active") // active, finished
  
  // Resultats
  winnerId    String?        // ID du BattlePlayer gagnant (modes solo)
  winnerTeam  Int?           // Pour 2v2 : equipe 1 ou 2
  
  players     BattlePlayer[]
  
  startedAt   DateTime       @default(now())
  finishedAt  DateTime?
  
  @@index([status])
  @@index([startedAt])
}

model BattlePlayer {
  id              String   @id @default(cuid())
  
  battleId        String
  battle          Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  
  // Deck (optionnel - peut etre cree a la volee)
  deckId          String?
  deck            Deck?    @relation(fields: [deckId], references: [id], onDelete: SetNull)
  deckName        String   // Nom affiche (meme si pas de deck lie)
  
  // Position et equipe
  playerOrder     Int      // Position 1-4
  team            Int?     // Pour 2v2 : equipe 1 ou 2
  
  // Stats de la partie
  startingLife    Int
  finalLife       Int      // PV a la fin de la partie
  victoryPoints   Int      @default(0)  // Pour mode 1v1v1
  isEliminated    Boolean  @default(false)
  
  // Commander Damage recu (JSON: { "playerOrderX": damage })
  commanderDamage Json     @default("{}")
  
  @@index([battleId])
  @@index([deckId])
}

// ============================================
// GAME SESSIONS (Multiplayer Playtest)
// ============================================

enum GameSessionStatus {
  waiting    // En attente de joueurs
  playing    // Partie en cours
  finished   // Partie terminée
}

model GameSession {
  id              String            @id @default(cuid())
  code            String            @unique  // Code court pour rejoindre (ex: "ABC123")
  name            String?           // Nom optionnel de la partie
  
  // Configuration
  maxPlayers      Int               @default(2)    // 2, 3 ou 4 joueurs
  startingLife    Int               @default(20)   // 20 ou 40 (commander)
  format          String?           // commander, modern, standard...
  
  // État
  status          GameSessionStatus @default(waiting)
  currentTurn     Int               @default(0)    // Tour actuel (0 = pas commencé)
  activePlayerId  String?           // ID du joueur dont c'est le tour
  
  // Joueurs
  players         GamePlayer[]
  
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  startedAt       DateTime?
  finishedAt      DateTime?
  
  @@index([code])
  @@index([status])
  @@index([createdAt])
}

model GamePlayer {
  id              String       @id @default(cuid())
  
  sessionId       String
  session         GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Identité
  name            String       // Nom du joueur
  color           String       @default("#D4AF37") // Couleur d'affichage
  isHost          Boolean      @default(false)     // Créateur de la session
  
  // Deck (optionnel)
  deckId          String?
  deckName        String?
  
  // État du jeu
  life            Int          @default(20)
  manaPool        Int          @default(0)
  poisonCounters  Int          @default(0)
  commanderDamage Json         @default("{}") // { "playerId": damage }
  
  // Zones (stockées en JSON pour simplicité)
  handCount       Int          @default(0)    // Nombre de cartes en main
  libraryCount    Int          @default(0)    // Cartes dans la bibliothèque
  graveyardCount  Int          @default(0)    // Cartes au cimetière
  exileCount      Int          @default(0)    // Cartes en exil
  battlefieldCount Int         @default(0)    // Permanents en jeu
  battlefieldCards Json        @default("[]") // Cartes visibles sur le battlefield [{id, name, image, type, tapped}]
  
  // Status
  isConnected     Boolean      @default(true)
  isEliminated    Boolean      @default(false)
  isReady         Boolean      @default(false)  // Prêt à commencer
  lastSeenAt      DateTime     @default(now())
  
  // Position
  playerOrder     Int          // 1-4
  
  // Timestamps
  joinedAt        DateTime     @default(now())
  
  @@unique([sessionId, playerOrder])
  @@index([sessionId])
}

// ============================================
// MATCHES (Parties physiques jouées)
// ============================================
model Match {
  id              String    @id @default(cuid())

  // Date de la partie
  playedAt        DateTime

  // Joueur 1 (moi)
  deck1Name       String    // Nom du deck (toujours renseigné)
  deck1Id         String?   // Lien vers deck si existant
  deck1           Deck?     @relation("Deck1Matches", fields: [deck1Id], references: [id], onDelete: SetNull)
  score1          Int       // Score (0, 1 ou 2 en best of 3)

  // Joueur 2 (adversaire)
  deck2Name       String    // Nom du deck adverse
  deck2Id         String?   // Lien vers deck si existant
  deck2           Deck?     @relation("Deck2Matches", fields: [deck2Id], references: [id], onDelete: SetNull)
  score2          Int       // Score adverse

  // Métadonnées optionnelles
  notes           String?   // Notes sur la partie
  format          String?   // Format si différent du deck

  // Import tracking
  importBatchId   String?   // Pour grouper les imports
  importedAt      DateTime  @default(now())

  @@index([playedAt])
  @@index([deck1Name])
  @@index([deck2Name])
  @@index([deck1Id])
  @@index([deck2Id])
  @@index([importBatchId])
}

// ============================================
// DECK SIMULATION (Goldfish Auto-Test)
// ============================================
model DeckSimulation {
  id              String   @id @default(cuid())
  
  deckId          String
  
  // Parametres de simulation
  iterations      Int      @default(10000)  // Nombre de tirages
  turnsSimulated  Int      @default(3)     // Nombre de tours joues
  isAdvanced      Boolean  @default(false) // Mode avance (mana rocks + terrains speciaux)
  
  // Stats sur les mains initiales (7 cartes)
  avgLandsInHand      Float   // Moyenne de terrains en main initiale
  avgNonLandsInHand   Float   // Moyenne de non-terrains
  avgCmcInHand        Float   // CMC moyen de la main
  
  // Distribution terrains main initiale (JSON: {0: count, 1: count, ...})
  landsDistribution   Json
  
  // Stats sur 3 tours (10 cartes vues)
  avgLandsTurn3       Float   // Moyenne de terrains apres 3 tours
  avgPlayablesTurn1   Float   // Cartes jouables tour 1 (CMC <= terrains)
  avgPlayablesTurn2   Float   // Cartes jouables tour 2
  avgPlayablesTurn3   Float   // Cartes jouables tour 3
  
  // Pourcentages utiles
  pctKeepableHands    Float   // % mains avec 2-5 terrains
  pctTurn1Play        Float   // % avec au moins 1 carte jouable T1
  pctTurn2Play        Float   // % avec au moins 1 carte jouable T2
  pctManaScrew        Float   // % mains avec 0-1 terrain
  pctManaFlood        Float   // % mains avec 5+ terrains
  
  // ============================================
  // COLOR FIXING ANALYSIS (Mode Avance)
  // ============================================
  // Sources de mana par couleur (compte les terrains/rocks qui produisent cette couleur)
  colorSources        Json?   // { W: 12, U: 8, B: 0, R: 0, G: 10, C: 4, ANY: 4 }
  
  // Besoins en couleur du deck (compte les symboles dans les couts de mana)
  colorNeeds          Json?   // { W: 25, U: 15, B: 0, R: 0, G: 30 }
  
  // Ratio sources/besoins par couleur (< 1 = probleme potentiel)
  colorRatios         Json?   // { W: 0.48, U: 0.53, G: 0.33 }
  
  // % de mains avec la bonne couleur T1, T2, T3 pour jouer les sorts correspondants
  pctColorFixedT1     Float?  // % mains ou on a les couleurs pour T1
  pctColorFixedT2     Float?  // % mains ou on a les couleurs pour T2
  pctColorFixedT3     Float?  // % mains ou on a les couleurs pour T3
  
  // ============================================
  // SPECIAL LANDS STATS (Mode Avance)
  // ============================================
  // Compte des types de terrains speciaux dans le deck
  landBreakdown       Json?   // { basics: 10, fetches: 4, shocks: 4, checks: 2, taplands: 3, mdfc: 2, bouncelands: 0 }
  
  // Impact des terrains tapped sur la disponibilite du mana
  avgManaAvailableT1  Float?  // Mana reel disponible T1 (apres tapped lands)
  avgManaAvailableT2  Float?  // Mana reel disponible T2
  avgManaAvailableT3  Float?  // Mana reel disponible T3
  
  // ============================================
  // EXEMPLE DE MAINS (pour debug/comprehension)
  // ============================================
  // 3 exemples de mains gardables (2-4 lands, spell jouable)
  sampleKeepHands     Json?   // [{ cards: ["Forest", "Plains", "Llanowar Elves", ...], lands: 3, t1Plays: 1 }, ...]
  
  // 3 exemples de mains a mulligan
  sampleMulliganHands Json?   // [{ cards: [...], lands: 6, reason: "flood" }, { ..., reason: "screw" }, ...]
  
  // Meta
  createdAt       DateTime @default(now())
  
  @@index([deckId])
  @@index([createdAt])
}